{
  "family": "ddd-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "3072",
  "containerDefinitions": [
    {
      "name": "app-server",
      "portMappings": [
        {
          "containerPort": 8080
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "SPRING_PROFILES_ACTIVE", "value": "prod"
        },
        {
          "name": "SPRING_CONFIG_IMPORT", "value": "aws-secretsmanager:/acc/ddd/prod/"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "ecs/spring/ddd-task",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "app"
        }
      }
    },
    {
      "name": "redis",
      "image": "redis:7.2",
      "portMappings": [
        {
          "containerPort": 6379
        }
      ],
      "essential": false
    }
  ]
}
