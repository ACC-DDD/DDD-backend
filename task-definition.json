{
  "family": "ddd-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [
    {
      "name": "app-server",
      "image": "{{DOCKER_USERNAME}}/{{DOCKER_REPO}}",
      "portMappings": [{ "containerPort": 8080 }],
      "essential": true,
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "prod" },
        { "name": "AWS_ACCESS_KEY", "value": "{{AWS_ACCESS_KEY}}" },
        { "name": "AWS_SECRET_KEY", "value": "{{AWS_SECRET_KEY}}" },
        { "name": "DYNAMO_REGION", "value": "{{DYNAMO_REGION}}" },
        { "name": "DYNAMO_ACCESS", "value": "{{DYNAMO_ACCESS}}" },
        { "name": "DYNAMO_SECRET", "value": "{{DYNAMO_SECRET}}" },
        { "name": "SQS_REGION", "value": "{{SQS_REGION}}" },
        { "name": "JWT_SECRET", "value": "{{JWT_SECRET}}" },
        { "name": "ACCESS_EXPIRATION", "value": "{{ACCESS_EXPIRATION}}" },
        { "name": "REFRESH_EXPIRATION", "value": "{{REFRESH_EXPIRATION}}" },
        { "name": "ITS_KEY", "value": "{{ITS_KEY}}" },
        { "name": "VWORLD_KEY", "value": "{{VWORLD_KEY}}" }
      ]
    },
    {
      "name": "redis",
      "image": "redis:7.2",
      "portMappings": [{ "containerPort": 6379 }],
      "essential": false
    }
  ]
}
